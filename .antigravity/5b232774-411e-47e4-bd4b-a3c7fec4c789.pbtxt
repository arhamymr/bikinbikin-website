        target_content: "          {/* Logo */}\n          <div \n            onClick={() => window.scrollTo({ top: 0, behavior: \"smooth\" })}\n            className=\"flex items-center space-x-2 cursor-pointer group\"\n          >\n            <div className=\"p-2.5 bg-emerald-600 rounded-xl text-white shadow-md shadow-emerald-200 transition-all group-hover:scale-105 duration-200\">\n              <Globe className=\"w-5 h-5 animate-pulse\" />\n            </div>\n            <div>\n              <span className=\"font-extrabold text-xl tracking-tight text-gray-900\">\n                Situs<span className=\"text-emerald-600\">Pro</span>\n              </span>\n              <span className=\"block text-[10px] font-medium tracking-widest uppercase text-gray-400\">\n                Studio Web\n              </span>\n            </div>\n          </div>\n\n          {/* Desktop Navigation */}\n          <nav className=\"hidden md:flex items-center space-x-8\">\n            <button\n              onClick={() => scrollToSection(\"mengapa-website\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Urgensi\n            </button>\n            <button\n              onClick={() => scrollToSection(\"layanan-utama\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Layanan\n            </button>\n            <button\n              onClick={() => scrollToSection(\"kalkulator-custom\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Kalkulator Harga\n            </button>\n            <button\n              onClick={() => scrollToSection(\"paket-website\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Paket\n            </button>\n            <button\n              onClick={() => scrollToSection(\"alur-kerja\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Alur Kerja\n            </button>\n            <button\n              onClick={() => scrollToSection(\"portofolio-kami\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Portofolio\n            </button>\n            <button\n              onClick={() => scrollToSection(\"faq-section\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              FAQ\n            </button>\n          </nav>\n\n          {/* Action Buttons */}\n          <div className=\"hidden lg:flex items-center space-x-3\">\n            <button\n              onClick={onOpenConsultation}\n              className=\"inline-flex items-center text-sm font-semibold text-gray-700 bg-gray-50 border border-gray-200 py-2 px-4 rounded-xl hover:bg-gray-100 transition-colors\"\n            >\n              <PhoneCall className=\"w-4 h-4 mr-1.5 text-emerald-600\" />\n              Konsultasi Gratis\n            </button>\n            <button\n              onClick={onNavigateToCalculator}\n              className=\"inline-flex items-center text-sm font-semibold text-white bg-emerald-600 py-2 px-4 rounded-xl hover:bg-emerald-700 transition-all shadow-md shadow-emerald-100 hover:shadow-emerald-200\"\n            >\n              <MessageSquare className=\"w-4 h-4 mr-1.5\" />\n              Lihat Desain & Paket\n            </button>\n          </div>\n\n          {/* Mobile Menu Button */}\n          <div className=\"flex md:hidden\">\n            <button\n              id=\"mobile-menu-btn\"\n              onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}\n              className=\"p-2 rounded-lg text-gray-600 hover:text-emerald-600 hover: