    instruction: "Update hero layout and coloring from emerald to indigo/slate to apply the Professional Polish theme"
    replacement_infos {
      original_chunk {
        target_content: "    <section id=\"hero-section\" className=\"relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden bg-radial from-emerald-50/60 via-white to-white\">\n      {/* Absolute Decorative Circles */}\n      <div className=\"absolute top-1/4 -left-64 w-96 h-96 bg-emerald-100 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob\" />\n      <div className=\"absolute top-1/3 -right-64 w-96 h-96 bg-blue-100 rounded-full mix-blend-multiply filter blur-3xl opacity-40 animate-blob\" />\n\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          {/* Hero Left Content */}\n          <div className=\"lg:col-span-7 space-y-6 text-center lg:text-left\">\n            <div className=\"inline-flex items-center space-x-1.5 py-1 px-3 bg-emerald-50 border border-emerald-100 rounded-full text-emerald-800 text-xs font-semibold uppercase tracking-wider\">\n              <Sparkles className=\"w-3.5 h-3.5 text-emerald-600 animate-spin-slow\" />\n              <span>Satu Solusi Untuk Sukses Digital</span>\n            </div>\n            \n            <h1 className=\"text-4xl sm:text-5xl md:text-6xl font-extrabold text-gray-900 leading-tight tracking-tight\">\n              Jasa Pembuatan Website <span className=\"text-emerald-600 relative inline-block\">\n                Profesional\n                <span className=\"absolute left-0 bottom-1 w-full h-2 bg-emerald-200/50 -z-10 rounded\" />\n              </span>\n            </h1>\n\n            <p className=\"text-lg text-gray-600 max-w-2xl mx-auto lg:mx-0 leading-relaxed\">\n              Website modern, cepat, dan responsif untuk membantu bisnis Anda tampil lebih profesional, dipercaya pelanggan, dan mudah ditemukan secara online. Kami bantu tumbuh kembang **UMKM**, **Perusahaan**, **Personal Brand**, maupun **Organisasi**.\n            </p>\n\n            {/* Quick trust checkmarks */}\n            <div className=\"flex flex-wrap justify-center lg:justify-start gap-4 text-xs font-semibold text-gray-700 pt-1\">\n              <span className=\"flex items-center space-x-1 bg-white px-3 py-1.5 rounded-full shadow-sm border border-gray-100\">\n                <CheckCircle className=\"w-4 h-4 text-emerald-500\" />\n                <span>Desain Premium</span>\n              </span>\n              <span className=\"flex items-center space-x-1 bg-white px-3 py-1.5 rounded-full shadow-sm border border-gray-100\">\n                <Zap className=\"w-4 h-4 text-amber-500 fill-amber-100\" />\n                <span>Super Cepat & SEO</span>\n              </span>\n              <span className=\"flex items-center space-x-1 bg-white px-3 py-1.5 rounded-full shadow-sm border border-gray-100\">\n                <Smartphone className=\"w-4 h-4 text-blue-500\" />\n                <span>100% Mobile Friendly</span>\n              </span>\n            </div>\n\n            {/* Call to Actions */}\n            <div className=\"flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-4\">\n              <button\n                onClick={onOpenConsultation}\n                dangerouslySetInnerHTML={{ __html: \"Konsultasi Gratis\" }}\n                id=\"hero-free-consultation\"\n                className=\"w-full sm:w-auto inline-flex items-center justify-center text-base font-bold text-white bg-emerald-600 hover:bg-emerald-700 py-4 px-8 rounded-2xl shadow-lg shadow-emerald-200 hover:shadow-emerald-300 transform hover:-translate-y-0.5 transition-all duration-200\"\n              />\n              <button\n                onClick={() => scrollToSection(\"paket-website\")}\n                id=\"hero-view-packages\"\n                className=\"w-full sm:w-auto inline-flex items-center justify-center text-base font-bold text-gray-700 bg-white border border-gray-200 hover:bg-gray-50 py-4 px-8 rounded-2xl hover:border-gray-300 transition-all duration-200\"\n              >\n                Lihat Paket Website\n                <ArrowRight className=\"w-4 h-4 ml-2 text-gray-400 stroke-[3px]\" />\n              </button>\n            </div>\n\n            {/* Client count summary */}\n            <div className=\"pt-8 border-t border-gray-100 flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left justify-center lg:justify-start\">\n              <div className=\"flex -space-x-2\">\n                <img className=\"w-9 h-9 rounded-full border-2 border-white object-cover\" src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=facearea&facepad=2&w=150&h=150&q=80\" alt=\"Client\" referrerPolicy=\"no-referrer\" />\n                <img className=\"w-9 h-9 rounded-full border-2 border-white object-cover\" src=\"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=facearea&facepad=2&w=150&h=150&q=80\" alt=\"Client\" referrerPolicy=\"no-referrer\" />\n                <img className=\"w-9 h-9 rounded-full border-2 border-white object-cover\" src=\"https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=facearea&facepad=2&w=150&h=150&q=80\" alt=\"Client\" referrerPolicy=\"no-referrer\" />\n              </div>\n              <div>\n                <p className=\"text-sm font-semibold text-gray-900\">\n                  Dipercaya oleh 140+ Bisnis di Indonesia\n                </p>\n                <p className=\"text-xs text-gray-500\">\n                  Dari Pemula UMKM hingga Perusahaan Korporat Nasional.\n                </p>\n              </div>\n            </div>\n          </div>\n\n          {/* Hero Right Visual Column */}\n          <div className=\"lg:col-span-5 relative\">\n            <div className=\"relative mx-auto max-w-[420px] lg:max-w-none\">\n              {/* Background gradient shadow */}\n              <div className=\"absolute -inset-2 bg-gradient-to-tr from-emerald-600 to-emerald-300 rounded-3xl opacity-10 blur-xl