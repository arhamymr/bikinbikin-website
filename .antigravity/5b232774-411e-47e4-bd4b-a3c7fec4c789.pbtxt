  file_change {
    absolute_path_uri: "file:///src/components/Layanan.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \"react\";\nimport { Briefcase, Store, Target, ShoppingBag, Terminal, CheckCircle2, ArrowRight } from \"lucide-react\";\nimport { SERVICES_LIST } from \"../data\";\n\ninterface LayananProps {\n  onNavigateToCalculator: () => void;\n}\n\nexport default function Layanan({ onNavigateToCalculator }: LayananProps) {\n  const [selectedService, setSelectedService] = useState<string>(\"company-profile\");\n\n  const getIcon = (iconName: string) => {\n    switch (iconName) {\n      case \"Briefcase\":\n        return <Briefcase className=\"w-6 h-6\" />;\n      case \"Store\":\n        return <Store className=\"w-6 h-6\" />;\n      case \"Target\":\n        return <Target className=\"w-6 h-6\" />;\n      case \"ShoppingBag\":\n        return <ShoppingBag className=\"w-6 h-6\" />;\n      case \"Terminal\":\n        return <Terminal className=\"w-6 h-6\" />;\n      default:\n        return <Briefcase className=\"w-6 h-6\" />;\n    }\n  };\n\n  const currentlySelected = SERVICES_LIST.find((s) => s.id === selectedService) || SERVICES_LIST[0];\n\n  return (\n    <section id=\"layanan-utama\" className=\"py-20 bg-white\">\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        \n        {/* Section Header */}\n        <div className=\"text-center max-w-3xl mx-auto space-y-4\">\n          <span className=\"text-xs font-bold uppercase tracking-widest text-emerald-600 bg-emerald-50 py-1 px-3 rounded-full\">\n            Solusi Web Terbaik\n          </span>\n          <h2 className=\"text-3xl sm:text-4xl font-extrabold text-gray-900 leading-tight\">\n            Layanan Pembuatan Website Kami\n          </h2>\n          <p className=\"text-base text-gray-600 leading-relaxed text-center\">\n            Kami menghadirkan berbagai jenis model website yang disesuaikan secara presisi dengan model bisnis Anda. Pilih model di bawah ini untuk melihat fitur utamanya.\n          </p>\n        </div>\n\n        {/* Tab Selection Row */}\n        <div className=\"mt-12 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3\">\n          {SERVICES_LIST.map((service) => {\n            const isActive = service.id === selectedService;\n            return (\n              <button\n                key={service.id}\n                onClick={() => setSelectedService(service.id)}\n                className={`p-4 rounded-2xl border text-center flex flex-col items-center justify-center space-y-3 transition-all cursor-pointer ${\n                  isActive\n                    ? \"bg-emerald-600 border-emerald-600 text-white shadow-lg shadow-emerald-100\"\n                    : \"bg-gray-50 hover:bg-gray-100 border-gray-150 text-gray-700\"\n                }`}\n              >\n                <div className={`p-2.5 rounded-xl ${isActive ? \"bg-white/25 text-white\" : \"bg-white text-emerald-600 shadow-sm border border-gray-100\"}`}>\n                  {getIcon(service.iconName)}\n                </div>\n                <span className=\"font-bold text-xs sm:text-sm tracking-tight leading-snug\">\n                  {service.title.replace(\"Website \", \"\")}\n                </span>\n              </button>\n            );\n          })}\n        </div>\n\n        {/* Detailed Spec Showcase Frame */}\n        <div className=\"mt-8 bg-gray-50/50 rounded-3xl border border-gray-150 overflow-hidden shadow-sm grid grid-cols-1 lg:grid-cols-2 gap-0\">\n          {/* Detailed features text */}\n          <div className=\"p-8 sm:p-12 space-y-6 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <div className=\"inline-flex items-center space-x-2\">\n                <div className={`p-2 rounded-xl text-xs font-bold ${currentlySelected.accent}`}>\n                  Pilihan Produk\n                </div>\n              </div>\n              <h3 className=\"text-2xl sm:text-3xl font-extrabold text-gray-950\">\n                {currentlySelected.title}\n              </h3>\n              <p className=\"text-sm sm:text-base text-gray-600 leading-relaxed\">\n                {currentlySelected.description}\n              </p>\n            </div>\n\n            {/* List of default specs included */}\n            <div className=\"space-y-3 pt-6 border-t border-gray-150\">\n              <p className=\"text-xs font-bold text-gray-500 uppercase tracking-widest\">\n                Fitur Standard yang Didapat:\n              </p>\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n                {currentlySelected.features.map((feature, idx) => (\n                  <div key={idx} className=\"flex items-start space-x-2 text-xs text-gray-700 font-medium\">\n                    <CheckCircle2 className=\"w-4 h-4 text-emerald-500 flex-shrink-0 mt-0.5\" />\n                    <span>{feature}</span>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            {/* CTA action */}\n            <div className=\"pt-8\">\n              <button\n                onClick={onNavigateToCalculator}\n                className=\"inline-flex items-center text-sm font-bold text-white bg-emerald-600 hover:bg-emerald-700 py-3 px-6 rounded-xl shadow transition-colors\"\n              >\n                Gunakan Kalkulator Custom\n                <ArrowRight className=\"w-4 h-4 ml-2\" />\n              </button>\n            </div>\n          </div>\n\n          {/* Graphical/Creative Showcase */}\n          <div className=\"bg-gradient-to-br from-emerald-950 to-emerald-900 p-8 sm:p-12 relative flex flex-col justify-center text-white overflow-hidden min-h-[300px]\">\n            {/* Background elements */}\n            <div className=\"absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-emerald-800/20 via-transparent to-transparent\" />\n            \n            <div className=\"relative z-10 space-y-6 max-w-sm\">\n              <span className=\"text-[10px] uppercase font-bold tracking-widest text-emerald-300 bg-white/10 py-1 px-2.5 rounded-full\">\n                SitusPro Engineering\n              </span>\n              <p className=\"text-xl sm:text-2xl font-bold leading-snug\">\n                \"Kami merancang website profesional yang tidak hanya cantik secara visual, namun juga fokus mendatangkan peningkatan penjualan.\"\n              </p>\n              <div className=\"flex items-center space-x-3\">\n                <div className=\"w-10 h-10 rounded-full bg-slate-200 overflow-hidden border border-emerald-500\">\n                  <img src=\"https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=150&q=80\" alt=\"Lead Designer\" className=\"object-cover w-full h-full\" referrerPolicy=\"no-referrer\" />\n                </div>\n                <div>\n                  <p className=\"text-xs font-bold text-white\">Yanti Rosyana</p>\n                  <p className=\"text-[10px] text-emerald-300\">Head of UX Architecture</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
