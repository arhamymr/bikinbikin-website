  file_change {
    absolute_path_uri: "file:///src/components/Header.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useEffect } from \"react\";\nimport { Globe, Menu, X, MessageSquare, PhoneCall } from \"lucide-react\";\n\ninterface HeaderProps {\n  onOpenConsultation: () => void;\n  onNavigateToCalculator: () => void;\n}\n\nexport default function Header({ onOpenConsultation, onNavigateToCalculator }: HeaderProps) {\n  const [isScrolled, setIsScrolled] = useState(false);\n  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);\n\n  useEffect(() => {\n    const handleScroll = () => {\n      if (window.scrollY > 10) {\n        setIsScrolled(true);\n      } else {\n        setIsScrolled(false);\n      }\n    };\n    window.addEventListener(\"scroll\", handleScroll);\n    return () => window.removeEventListener(\"scroll\", handleScroll);\n  }, []);\n\n  const scrollToSection = (id: string) => {\n    setIsMobileMenuOpen(false);\n    const element = document.getElementById(id);\n    if (element) {\n      const offset = 80; // offset for sticky header\n      const bodyRect = document.body.getBoundingClientRect().top;\n      const elementRect = element.getBoundingClientRect().top;\n      const elementPosition = elementRect - bodyRect;\n      const offsetPosition = elementPosition - offset;\n\n      window.scrollTo({\n        top: offsetPosition,\n        behavior: \"smooth\"\n      });\n    }\n  };\n\n  return (\n    <header\n      id=\"main-nav-header\"\n      className={`fixed top-0 left-0 w-full z-50 transition-all duration-300 ${\n        isScrolled\n          ? \"bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100 py-3\"\n          : \"bg-transparent py-5\"\n      }`}\n    >\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        <div className=\"flex items-center justify-between\">\n          {/* Logo */}\n          <div \n            onClick={() => window.scrollTo({ top: 0, behavior: \"smooth\" })}\n            className=\"flex items-center space-x-2 cursor-pointer group\"\n          >\n            <div className=\"p-2.5 bg-emerald-600 rounded-xl text-white shadow-md shadow-emerald-200 transition-all group-hover:scale-105 duration-200\">\n              <Globe className=\"w-5 h-5 animate-pulse\" />\n            </div>\n            <div>\n              <span className=\"font-extrabold text-xl tracking-tight text-gray-900\">\n                Situs<span className=\"text-emerald-600\">Pro</span>\n              </span>\n              <span className=\"block text-[10px] font-medium tracking-widest uppercase text-gray-400\">\n                Studio Web\n              </span>\n            </div>\n          </div>\n\n          {/* Desktop Navigation */}\n          <nav className=\"hidden md:flex items-center space-x-8\">\n            <button\n              onClick={() => scrollToSection(\"mengapa-website\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Urgensi\n            </button>\n            <button\n              onClick={() => scrollToSection(\"layanan-utama\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Layanan\n            </button>\n            <button\n              onClick={() => scrollToSection(\"kalkulator-custom\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Kalkulator Harga\n            </button>\n            <button\n              onClick={() => scrollToSection(\"paket-website\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Paket\n            </button>\n            <button\n              onClick={() => scrollToSection(\"alur-kerja\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Alur Kerja\n            </button>\n            <button\n              onClick={() => scrollToSection(\"portofolio-kami\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              Portofolio\n            </button>\n            <button\n              onClick={() => scrollToSection(\"faq-section\")}\n              className=\"text-sm font-medium text-gray-600 hover:text-emerald-600 transition-colors\"\n            >\n              FAQ\n            </button>\n          </nav>\n\n          {/* Action Buttons */}\n          <div className=\"hidden lg:flex items-center space-x-3\">\n            <button\n              onClick={onOpenConsultation}\n              className=\"inline-flex items-center text-sm font-semibold text-gray-700 bg-gray-50 border border-gray-200 py-2 px-4 rounded-xl hover:bg-gray-100 transition-colors\"\n            >\n              <PhoneCall className=\"w-4 h-4 mr-1.5 text-emerald-600\" />\n              Konsultasi Gratis\n            </button>\n            <button\n              onClick={onNavigateToCalculator}\n              className=\"inline-flex items-center text-sm font-semibold text-white bg-emerald-600 py-2 px-4 rounded-xl hover:bg-emerald-700 transition-all shadow-md shadow-emerald-100 hover:shadow-emerald-200\"\n            >\n              <MessageSquare className=\"w-4 h-4 mr-1.5\" />\n              Lihat Desain & Paket\n            </button>\n          </div>\n\n          {/* Mobile Menu Button */}\n          <div className=\"flex md:hidden\">\n            <button\n              id=\"mobile-menu-btn\"\n              onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}\n              className=\"p-2 rounded-lg text-gray-600 hover:text-emerald-600 hover:bg-gray-50 focus:outline-none\"\n            >\n              {isMobileMenuOpen ? (\n                <X className=\"w-6 h-6\" />\n              ) : (\n                <Menu className=\"w-6 h-6\" />\n              )}\n            </button>\n          </div>\n        </div>\n      </div>\n\n      {/* Mobile Drawer */}\n      {isMobileMenuOpen && (\n        <div id=\"mobile-drawer\" className=\"md:hidden bg-white/95 backdrop-blur-md border-b border-gray-100 py-5 transition-all duration-300\">\n          <div className=\"px-4 space-y-4 flex flex-col\">\n            <button\n              onClick={() => scrollToSection(\"mengapa-website\")}\n              className=\"text-left font-medium text-gray-700 hover:text-emerald-600 py-2 border-b border-gray-50\"\n            >\n              Urgensi Website\n            </button>\n            <button\n              onClick={() => scrollToSection(\"layanan-utama\")}\n              className=\"text-left font-medium text-gray-700 hover:text-emerald-600 py-2 border-b border-gray-50\"\n            >\n              Layanan & Fitur\n            </button>\n            <button\n              onClick={() => scrollToSection(\"kalkulator-custom\")}\n              className=\"text-left font-medium text-gray-700 hover:text-emerald-600 py-2 border-b border-gray-50\"\n            >\n              Kalkulator Harga & Desain Preview\n            </button>\n            <button\n              onClick={() => scrollToSection(\"paket-website\")}\n              className=\"text-left font-medium text-gray-700 hover:text-emerald-600 py-2 border-b border-gray-50\"\n            >\n              Daftar Paket Harga\n            </button>\n            <button\n              onClick={() => scrollToSection(\"alur-kerja\")}\n              className=\"text-left font-medium text-gray-700 hover:text-emerald-600 py-2 border-b border-gray-50\"\n            >\n              Alur Kerja Kami\n            </button>\n            <button\n              onClick={() => scrollToSection(\"portofolio-kami\")}\n              className=\"text-left font-medium text-gray-700 hover:text-emerald-600 py-2 border-b border-gray-50\"\n            >\n              Portofolio Kami\n            </button>\n            <button\n              onClick={() => scrollToSection(\"faq-section\")}\n              className=\"text-left font-medium text-gray-700 hover:text-emerald-600 py-2 border-b border-gray-50\"\n            >\n              F.A.Q\n            </button>\n            <div className=\"pt-2 space-y-2\">\n              <button\n                onClick={() => {\n                  setIsMobileMenuOpen(false);\n                  onOpenConsultation();\n                }}\n                className=\"w-full inline-flex items-center justify-center text-sm font-semibold text-gray-700 bg-gray-50 border border-gray-200 py-2.5 px-4 rounded-xl hover:bg-gray-100 transition-colors\"\n              >\n                <PhoneCall className=\"w-4 h-4 mr-1.5 text-emerald-600\" />\n                Konsultasi Gratis\n              </button>\n              <button\n                onClick={() => {\n                  setIsMobileMenuOpen(false);\n                  scrollToSection(\"kalkulator-custom\");\n                }}\n                className=\"w-full inline-flex items-center justify-center text-sm font-semibold text-white bg-emerald-600 py-2.5 px-4 rounded-xl hover:bg-emerald-700 transition-all shadow-md shadow-emerald-100\"\n              >\n                <MessageSquare className=\"w-4 h-4 mr-1.5\" />\n                Desain & Estimasi Harga\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n    </header>\n  );\n}\n"
    }
