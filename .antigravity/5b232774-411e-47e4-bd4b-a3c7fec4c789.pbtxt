  file_change {
    absolute_path_uri: "file:///src/components/Hero.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React from \"react\";\nimport { ArrowRight, Sparkles, ShieldCheck, Zap, Smartphone, CheckCircle } from \"lucide-react\";\n\ninterface HeroProps {\n  onOpenConsultation: () => void;\n  onNavigateToCalculator: () => void;\n}\n\nexport default function Hero({ onOpenConsultation, onNavigateToCalculator }: HeroProps) {\n  const scrollToSection = (id: string) => {\n    const element = document.getElementById(id);\n    if (element) {\n      const offset = 80;\n      const bodyRect = document.body.getBoundingClientRect().top;\n      const elementRect = element.getBoundingClientRect().top;\n      const elementPosition = elementRect - bodyRect;\n      const offsetPosition = elementPosition - offset;\n\n      window.scrollTo({\n        top: offsetPosition,\n        behavior: \"smooth\"\n      });\n    }\n  };\n\n  return (\n    <section id=\"hero-section\" className=\"relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden bg-radial from-emerald-50/60 via-white to-white\">\n      {/* Absolute Decorative Circles */}\n      <div className=\"absolute top-1/4 -left-64 w-96 h-96 bg-emerald-100 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob\" />\n      <div className=\"absolute top-1/3 -right-64 w-96 h-96 bg-blue-100 rounded-full mix-blend-multiply filter blur-3xl opacity-40 animate-blob\" />\n\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          {/* Hero Left Content */}\n          <div className=\"lg:col-span-7 space-y-6 text-center lg:text-left\">\n            <div className=\"inline-flex items-center space-x-1.5 py-1 px-3 bg-emerald-50 border border-emerald-100 rounded-full text-emerald-800 text-xs font-semibold uppercase tracking-wider\">\n              <Sparkles className=\"w-3.5 h-3.5 text-emerald-600 animate-spin-slow\" />\n              <span>Satu Solusi Untuk Sukses Digital</span>\n            </div>\n            \n            <h1 className=\"text-4xl sm:text-5xl md:text-6xl font-extrabold text-gray-900 leading-tight tracking-tight\">\n              Jasa Pembuatan Website <span className=\"text-emerald-600 relative inline-block\">\n                Profesional\n                <span className=\"absolute left-0 bottom-1 w-full h-2 bg-emerald-200/50 -z-10 rounded\" />\n              </span>\n            </h1>\n\n            <p className=\"text-lg text-gray-600 max-w-2xl mx-auto lg:mx-0 leading-relaxed\">\n              Website modern, cepat, dan responsif untuk membantu bisnis Anda tampil lebih profesional, dipercaya pelanggan, dan mudah ditemukan secara online. Kami bantu tumbuh kembang **UMKM**, **Perusahaan**, **Personal Brand**, maupun **Organisasi**.\n            </p>\n\n            {/* Quick trust checkmarks */}\n            <div className=\"flex flex-wrap justify-center lg:justify-start gap-4 text-xs font-semibold text-gray-700 pt-1\">\n              <span className=\"flex items-center space-x-1 bg-white px-3 py-1.5 rounded-full shadow-sm border border-gray-100\">\n                <CheckCircle className=\"w-4 h-4 text-emerald-500\" />\n                <span>Desain Premium</span>\n              </span>\n              <span className=\"flex items-center space-x-1 bg-white px-3 py-1.5 rounded-full shadow-sm border border-gray-100\">\n                <Zap className=\"w-4 h-4 text-amber-500 fill-amber-100\" />\n                <span>Super Cepat & SEO</span>\n              </span>\n              <span className=\"flex items-center space-x-1 bg-white px-3 py-1.5 rounded-full shadow-sm border border-gray-100\">\n                <Smartphone className=\"w-4 h-4 text-blue-500\" />\n                <span>100% Mobile Friendly</span>\n              </span>\n            </div>\n\n            {/* Call to Actions */}\n            <div className=\"flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-4\">\n              <button\n                onClick={onOpenConsultation}\n                dangerouslySetInnerHTML={{ __html: \"Konsultasi Gratis\" }}\n                id=\"hero-free-consultation\"\n                className=\"w-full sm:w-auto inline-flex items-center justify-center text-base font-bold text-white bg-emerald-600 hover:bg-emerald-700 py-4 px-8 rounded-2xl shadow-lg shadow-emerald-200 hover:shadow-emerald-300 transform hover:-translate-y-0.5 transition-all duration-200\"\n              />\n              <button\n                onClick={() => scrollToSection(\"paket-website\")}\n                id=\"hero-view-packages\"\n                className=\"w-full sm:w-auto inline-flex items-center justify-center text-base font-bold text-gray-700 bg-white border border-gray-200 hover:bg-gray-50 py-4 px-8 rounded-2xl hover:border-gray-300 transition-all duration-200\"\n              >\n                Lihat Paket Website\n                <ArrowRight className=\"w-4 h-4 ml-2 text-gray-400 stroke-[3px]\" />\n              </button>\n            </div>\n\n            {/* Client count summary */}\n            <div className=\"pt-8 border-t border-gray-100 flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left justify-center lg:justify-start\">\n              <div className=\"flex -space-x-2\">\n                <img className=\"w-9 h-9 rounded-full border-2 border-white object-cover\" src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=facearea&facepad=2&w=150&h=150&q=80\" alt=\"Client\" referrerPolicy=\"no-referrer\" />\n                <img className=\"w-9 h-9 rounded-full border-2 border-white object-cover\" src=\"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=facearea&facepad=2&w=150&h=150&q=80\" alt=\"Client\" referrerPolicy=\"no-referrer\" />\n                <img className=\"w-9 h-9 rounded-full border-2 border-white object-cover\" src=\"https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=facearea&facepad=2&w=150&h=150&q=80\" alt=\"Client\" referrerPolicy=\"no-referrer\" />\n              </div>\n              <div>\n                <p className=\"text-sm font-semibold text-gray-900\">\n                  Dipercaya oleh 140+ Bisnis di Indonesia\n                </p>\n                <p className=\"text-xs text-gray-500\">\n                  Dari Pemula UMKM hingga Perusahaan Korporat Nasional.\n                </p>\n              </div>\n            </div>\n          </div>\n\n          {/* Hero Right Visual Column */}\n          <div className=\"lg:col-span-5 relative\">\n            <div className=\"relative mx-auto max-w-[420px] lg:max-w-none\">\n              {/* Background gradient shadow */}\n              <div className=\"absolute -inset-2 bg-gradient-to-tr from-emerald-600 to-emerald-300 rounded-3xl opacity-10 blur-xl\" />\n\n              {/* Glassmorphism Browser Window mockup */}\n              <div className=\"relative border border-gray-200/80 bg-white rounded-3xl shadow-2xl overflow-hidden\">\n                {/* Simulated Browser Bar */}\n                <div className=\"bg-gray-50 border-b border-gray-100 px-4 py-3 flex items-center justify-between\">\n                  {/* Window dots */}\n                  <div className=\"flex space-x-1.5\">\n                    <span className=\"w-3 h-3 rounded-full bg-rose-400 block\" />\n                    <span className=\"w-3 h-3 rounded-full bg-amber-400 block\" />\n                    <span className=\"w-3 h-3 rounded-full bg-emerald-400 block\" />\n                  </div>\n                  {/* Fake url bar */}\n                  <div className=\"bg-gray-25/50 border border-gray-150/70 rounded-lg text-[10px] text-gray-400 font-mono py-1 px-8 w-2/3 text-center truncate\">\n                    situspro.co.id/client-preview\n                  </div>\n                  <div className=\"w-6\" /> {/* Placeholder spacing */}\n                </div>\n\n                {/* Live mockup graphic illustration */}\n                <div className=\"p-5 space-y-4 bg-slate-25\">\n                  <div className=\"flex items-center justify-between\">\n                    <div className=\"h-5 w-20 bg-gray-200 rounded animate-pulse\" />\n                    <div className=\"flex space-x-2\">\n                      <div className=\"h-3 w-8 bg-gray-100 rounded\" />\n                      <div className=\"h-3 w-8 bg-gray-100 rounded\" />\n                      <div className=\"h-3 w-8 bg-gray-100 rounded\" />\n                    </div>\n                  </div>\n                  \n                  {/* Hero banner mock */}\n                  <div className=\"h-32 bg-slate-100 rounded-2xl flex flex-col justify-end p-4 relative overflow-hidden group\">\n                    <div className=\"absolute inset-0 bg-gradient-to-t from-emerald-950/80 via-transparent to-transparent z-10\" />\n                    <img \n                      src=\"https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=600&q=80\" \n                      alt=\"Website Preview\" \n                      className=\"absolute inset-0 object-cover w-full h-full group-hover:scale-105 transition-all duration-300\"\n                      referrerPolicy=\"no-referrer\"\n                    />\n                    <div className=\"relative z-20 text-white space-y-1\">\n                      <div className=\"h-3.5 w-24 bg-white/40 backdrop-blur rounded\" />\n                      <div className=\"h-2 w-16 bg-white/20 backdrop-blur rounded\" />\n                    </div>\n                  </div>\n\n                  {/* 3 Grid features mock */}\n                  <div className=\"grid grid-cols-3 gap-3\">\n                    <div className=\"bg-white p-2.5 rounded-xl border border-gray-100 text-center space-y-1 hover:border-emerald-100 transition-all\">\n                      <div className=\"flex justify-center\">\n                        <Zap className=\"w-5 h-5 text-amber-500 fill-amber-50\" />\n                      </div>\n                      <p className=\"text-[10px] font-bold text-gray-800\">Cepat</p>\n                      <p className=\"text-[8px] text-gray-400\">PageSpeed 99+</p>\n                    </div>\n                    <div className=\"bg-white p-2.5 rounded-xl border border-gray-100 text-center space-y-1 hover:border-emerald-100 transition-all\">\n                      <div className=\"flex justify-center\">\n                        <ShieldCheck className=\"w-5 h-5 text-emerald-500\" />\n                      </div>\n                      <p className=\"text-[10px] font-bold text-gray-800\">SEO Oke</p>\n                      <p className=\"text-[8px] text-gray-400\">Rapi di Google</p>\n                    </div>\n                    <div className=\"bg-white p-2.5 rounded-xl border border-gray-100 text-center space-y-1 hover:border-emerald-100 transition-all\">\n                      <div className=\"flex justify-center\">\n                        <Smartphone className=\"w-5 h-5 text-blue-500\" />\n                      </div>\n                      <p className=\"text-[10px] font-bold text-gray-800\">Mobile</p>\n                      <p className=\"text-[8px] text-gray-400\">Sempurna HP</p>\n                    </div>\n                  </div>\n\n                  {/* Live WhatsApp floating widget mockup */}\n                  <div className=\"bg-emerald-50 border border-emerald-100 p-3 rounded-2xl flex items-center justify-between\">\n                    <div className=\"flex items-center space-x-2\">\n                      <div className=\"w-8 h-8 rounded-full bg-emerald-600 flex items-center justify-center text-white text-xs font-bold shadow shadow-emerald-200\">\n                        WA\n                      </div>\n                      <div>\n                        <p className=\"text-[10px] font-bold text-emerald-950\">Integrasi WhatsApp</p>\n                        <p className=\"text-[8px] text-emerald-600\">Klik langsung chat admin</p>\n                      </div>\n                    </div>\n                    <div className=\"h-5 w-14 bg-emerald-600 text-white text-[9px] font-bold flex items-center justify-center rounded-lg shadow-sm\">\n                      Aktif \342\234\223\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              {/* Floating Widget 1 */}\n              <div className=\"absolute -bottom-6 -left-6 bg-white p-3.5 rounded-2xl shadow-xl border border-gray-100 flex items-center space-x-3 max-w-[200px] animate-bounce-slow\">\n                <div className=\"p-2 bg-emerald-100 rounded-xl text-emerald-700\">\n                  <ShieldCheck className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <p className=\"text-xs font-bold text-gray-900\">Garansi Maintenance</p>\n                  <p className=\"text-[9px] text-gray-500\">Dukungan penuh pasca jadi</p>\n                </div>\n              </div>\n\n              {/* Floating Widget 2 (Speed indicators) */}\n              <div className=\"absolute -top-6 -right-6 bg-white p-3.5 rounded-2xl shadow-xl border border-gray-100 flex items-center space-x-3 max-w-[150px]\">\n                <div className=\"p-2 bg-amber-50 rounded-xl text-amber-600\">\n                  <Zap className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <p className=\"text-xs font-bold text-gray-900\">Kecepatan</p>\n                  <p className=\"text-[10px] font-semibold text-emerald-600 font-mono\">Load &lt; 1s</p>\n                </div>\n              </div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    }
