    replacement_chunks {
      target_content: "  const urgensiItems = [\n    {\n      icon: <Laptop className=\"w-6 h-6 text-emerald-600\" />,\n      title: \"Kredibilitas Bisnis Instan\",\n      desc: \"Menampilkan profil bisnis, visi misi, legalitas, dan testimoni agar bisnis Anda segera dipercaya oleh khalayak umum.\"\n    },\n    {\n      icon: <ClipboardList className=\"w-6 h-6 text-blue-600\" />,\n      title: \"Satu Hub Informasi Rapi\",\n      desc: \"Profil, katalog, daftar produk, lokasi Google Maps, jam operasional, hingga formulir pesanan tersaji lengkap di satu alamat premium.\"\n    },\n    {\n      icon: <Search className=\"w-6 h-6 text-amber-600\" />,\n      title: \"Mudah Ditemukan Konsumen\",\n      desc: \"Sebelum membeli, calon pelanggan mencari di internet. Website memastikan brand Anda yang pertama muncul daripada kompetitor.\"\n    },\n    {\n      icon: <Eye className=\"w-6 h-6 text-purple-600\" />,\n      title: \"Eksistensi Digital 24 Jam\",\n      desc: \"Kantor & toko fisik memiliki jam operasional terbatas, namun website tetap aktif memajang katalog produk Anda non-stop sepanjang tahun.\"\n    }\n  ];\n\n  const keunggulanItems = [\n    {\n      icon: <Sparkles className=\"w-6 h-6 text-rose-600\" />,\n      title: \"Desain Profesional & Eksklusif\",\n      desc: \"Tampilan visual website modern, rapi, bersih, dan memadukan identitas orisinil dari brand Anda.\"\n    },\n    {\n      icon: <Laptop className=\"w-6 h-6 text-emerald-600\" />,\n      title: \"100% Mobile Friendly\",\n      desc: \"Struktur layout ramah dinamis, sangat nyaman diakses dari layar handphone, tablet, maupun layar monitor laptop.\"\n    },\n    {\n      icon: <Search className=\"w-6 h-6 text-blue-600\" />,\n      title: \"Infrastruktur SEO Basic\",\n      desc: \"Struktur heading ramah mesin pencari kustomisasi meta-title agar website Anda direkam Google dengan mulus.\"\n    },\n    {\n      icon: <Sliders className=\"w-6 h-6 text-indigo-600\" />,\n      title: \"Sistem Kelola Mandiri\",\n      desc: \"Konten teks, foto produk, testimoni dapat diubah dengan mudah dan gampang menggunakan panel kendali ramah pemula.\"\n    },\n    {\n      icon: <HeartHandshake className=\"w-6 h-6 text-amber-600\" />,\n      title: \"Support Penuh Pasca Jadi\",\n      desc: \"Kami tetap mendampingi setelah website selesai dideploy agar Anda tidak bingung saat pertama kali mengoperasikannya.\"\n    },\n    {\n      icon: <Shield className=\"w-6 h-6 text-emerald-600\" />,\n      title: \"Optimal, Cepat & Ringan\",\n      desc: \"Kami mengutamakan performa loading web super optimal demi meminimalkan pelanggan keluar karena loading yang lemot.\"\n    }\n  ];\n\n  return (\n    <section id=\"mengapa-website\" className=\"py-20 bg-gray-50/70 border-y border-gray-100\">\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        \n        {/* Section Header */}\n        <div className=\"text-center max-w-3xl mx-auto space-y-4\">\n          <span className=\"text-xs font-bold uppercase tracking-widest text-emerald-600 bg-emerald-50 py-1 px-3 rounded-full\">\n            Eksistensi Digital\n          </span>\n          <h2 className=\"text-3xl sm:text-4xl font-extrabold text-gray-900 leading-tight\">\n            Kenapa Bisnis Anda Butuh Website?\n          </h2>\n          <p className=\"text-base text-gray-600 leading-relaxed\">\n            Di era digital, pelanggan sering mencari informasi melalui internet sebelum membeli produk atau menggunakan jasa. Website membantu bisnis Anda terlihat lebih kredibel dan mudah dijangkau kapan saja.\n          </p>\n        </div>\n\n        {/* Tab Selection */}\n        <div className=\"flex justify-center mt-10\">\n          <div className=\"inline-flex bg-white p-1 rounded-2xl border border-gray-150 shadow-sm\">\n            <button\n              onClick={() => setActiveTab(\"urgensi\")}\n              className={`py-2 px-6 rounded-xl text-sm font-bold transition-all ${\n                activeTab === \"urgensi\"\n                  ? \"bg-emerald-600 text-white shadow\"\n                  : \"text-gray-600 hover:text-gray-900 hover:bg-gray-50\"\n              }`}\n            >\n              Urgensi Website Bisnis\n            </button>\n            <button\n              onClick={() => setActiveTab(\"keunggulan\")}\n              className={`py-2 px-6 rounded-xl text-sm font-bold transition-all ${\n                activeTab === \"keunggulan\"\n                  ? \"bg-emerald-600 text-white shadow\"\n                  : \"text-gray-600 hover:text-gray-900 hover:bg-gray-50\"\n              }`}\n            >\n              Keunggulan Layanan Kami\n            </button>\n          </div>\n        </div>\n\n        {/* Dynamic Items Grid */}\n        <div className=\"mt-12\">\n          {activeTab === \"urgensi\" ? (\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n              {urgensiItems.map((item, idx) => (\n                <div\n                  key={idx}\n                  className=\"bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-start space-x-4 hover:border-emerald-200 hover:shadow transition-all duration-300\"\n                >\n                  <div className=\"p-3 bg-gray-50 rounded-xl flex-shrink-0\">\n                    {item.icon}\n                  </div>\n                  <div className=\"space-y-1.5ClassName bg-transparent\">\n                    <h3 className=\"font-bold text-lg text-gray-900\">{item.title}</h3>\n                    <p className=\"text-sm text-gray-600 leading-relaxed\">{item.desc}</p>\n                  </div>\n                </div>\n              ))}\n            </div>\n          ) : (\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n              {keunggulanItems.map((item, idx) => (\n                <div\n                  key={idx}\n                  className=\"bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex flex-col justify-between hover:border-emerald-200 hover:shadow transition-all duration-300\"\n                >\n                  <div className=\"space-y-4\">\n                    <div className=\"p-3 bg-gray-50 rounded-xl inline-block\">\n                      {item.icon}\n                    </div>\n                    <div className=\"space-y-2\">\n                      <h4 className=\"font-bold text-base text-gray-900\">{item.title}</h4>\n                      <p className=\"text-xs text-gray-600 leading-relaxed\">{item.desc}</p>\n                    </div>\n                  </div>\n                  <div className=\"pt-4 flex items-center text-xs font-bold text-emerald-600\">\n                    SitusPro Quality Guarantee \342\234\223\n                  </div>\n                </div>\n              ))}\n            </div>\n          )}\n        </div>\n\n        {/* Custom Visual Callout */}\n        <div className=\"mt-12 bg-emerald-950 text-white rounded-3xl p-6 sm:p-10 relative overflow-hidden shadow-xl\">\n          {/* Decorative elements */}\n          <div className=\"absolute top-0 right-0 w-64 h-64 bg-emerald-800 rounded-full mix-blend-multiply opacity-20 filter blur-2xl pointer-events-none\" />\n          <div className=\"relative z-10 flex flex-col md:flex-row items-center justify-between gap-6\">\n            <div className=\"space-y-2 text-center md:text-left max-w-xl\">\n              <h4 className=\"text-xl sm:text-2xl font-bold\">Gabungkan Profil, Layanan, & Kontak Dalam Satu Tempat</h4>\n              <p className=\"text-xs sm:text-sm text-emerald-100 leading-relaxed\">\n                Kami siap merancang website responsive yang terintegrasi penuh ke Google Maps dan WhatsApp bisnis Anda. Kredibilitas instan, peningkatan konversi, dan kepuasan pelanggan menanti Anda.\n              </p>\n            </div>\n            <button\n              onClick={() => {\n                const cal = document.getElementById(\"kalkulator-custom\");\n                if (cal) cal.scrollIntoView({ behavior: \"smooth\" });\n              }}\n              className=\"bg-white text-emerald-950 hover:bg-emerald-50 py-3.5 px-6 rounded-xl text-sm font-bold shadow-md shrink-0 transition-colors\"\n            >\n              Coba Kalkulator Desain Preview\n            </button>\n          </div>\n        </div>"
      replacement_content: "  const urgensiItems = [\n    {\n      icon: <Laptop className=\"w-6 h-6 text-indigo-700\" />,\n      title: \"Kredibilitas Bisnis Instan\",\n      desc: \"Menampilkan profil bisnis, visi misi, legalitas, dan testimoni agar bisnis Anda segera dipercaya oleh khalayak umum.\"\n    },\n    {\n      icon: <ClipboardList className=\"w-6 h-6 text-blue-600\" />,\n      title: \"Satu Hub Informasi Rapi\",\n      desc: \"Profil, katalog, daftar produk, lokasi Google Maps, jam operasional, hingga formulir pesanan tersaji lengkap di satu alamat premium.\"\n    },\n    {\n      icon: <Search className=\"w-6 h-6 text-amber-600\" />,\n      title: \"Mudah Ditemukan Konsumen\",\n      desc: \"Sebelum membeli, calon pelanggan mencari di internet. Website memastikan brand Anda yang pertama muncul daripada kompetitor.\"\n    },\n    {\n      icon: <Eye className=\"w-6 h-6 text-purple-600\" />,\n      title: \"Eksistensi Digital 24 Jam\",\n      desc: \"Kantor & toko fisik memiliki jam operasional terbatas, namun website tetap aktif memajang katalog produk Anda non-stop sepanjang tahun.\"\n    }\n  ];\n\n  const keunggulanItems = [\n    {\n      icon: <Sparkles className=\"w-6 h-6 text-rose-600\" />,\n      title: \"Desain Profesional & Eksklusif\",\n      desc: \"Tampilan visual website modern, rapi, bersih, dan memadukan identitas orisinil dari brand Anda.\"\n    },\n    {\n      icon: <Laptop className=\"w-6 h-6 text-indigo-700\" />,\n      title: \"100% Mobile Friendly\",\n      desc: \"Struktur layout ramah dinamis, sangat nyaman diakses dari layar handphone, tablet, maupun layar monitor laptop.\"\n    },\n    {\n      icon: <Search className=\"w-6 h-6 text-blue-600\" />,\n      title: \"Infrastruktur SEO Basic\",\n      desc: \"Struktur heading ramah mesin pencari kustomisasi meta-title agar website Anda direkam Google dengan mulus.\"\n    },\n    {\n      icon: <Sliders className=\"w-6 h-6 text-indigo-600\" />,\n      title: \"Sistem Kelola Mandiri\",\n      desc: \"Konten teks, foto produk, testimoni dapat diubah dengan mudah dan gampang menggunakan panel kendali ramah pemula.\"\n    },\n    {\n      icon: <HeartHandshake className=\"w-6 h-6 text-amber-600\" />,\n      title: \"Support Penuh Pasca Jadi\",\n      desc: \"Kami tetap mendampingi setelah website selesai dideploy agar Anda tidak bingung saat pertama kali mengoperasikannya.\"\n    },\n    {\n      icon: <Shield className=\"w-6 h-6 text-indigo-700\" />,\n      title: \"Optimal, Cepat & Ringan\",\n      desc: \"Kami mengutamakan performa loading web super optimal demi meminimalkan pelanggan keluar karena loading yang lemot.\"\n    }\n  ];\n\n  return (\n    <section id=\"mengapa-website\" className=\"py-20 bg-slate-50 border-y border-slate-200\">\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        \n        {/* Section Header */}\n        <div className=\"text-center max-w-3xl mx-auto space-y-4\">\n          <span className=\"text-xs font-bold uppercase tracking-widest text-indigo-700 bg-indigo-50 px-3 py-1 rounded-full\">\n            Eksistensi Digital\n          </span>\n          <h2 className=\"text-3xl sm:text-4xl font-extrabold text-slate-900 leading-tight\">\n            Kenapa Bisnis Anda Butuh Website?\n          </h2>\n          <p className=\"text-base text-slate-600 leading-relaxed\">\n            Di era digital, pelanggan sering mencari informasi melalui internet sebelum membeli produk atau menggunakan jasa. Website membantu bisnis Anda terlihat lebih kredibel dan mudah dijangkau kapan saja.\n          </p>\n        </div>\n\n        {/* Tab Selection */}\n        <div className=\"flex justify-center mt-10\">\n          <div className=\"inline-flex bg-white p-1 rounded-full border border-slate-200 shadow-sm\">\n            <button\n              onClick={() => setActiveTab(\"urgensi\")}\n              className={`py-2 px-6 rounded-full text-sm font-bold transition-all ${\n                activeTab === \"urgensi\"\n                  ? \"bg-indigo-700 text-white shadow-md shadow-indigo-100\"\n                  : \"text-slate-600 hover:text-slate-950 hover:bg-slate-50\"\n              }`}\n            >\n              Urgensi Website Bisnis\n            </button>\n            <button\n              onClick={() => setActiveTab(\"keunggulan\")}\n              className={`py-2 px-6 rounded-full text-sm font-bold transition-all ${\n                activeTab === \"keunggulan\"\n                  ? \"bg-indigo-700 text-white shadow-md shadow-indigo-100\"\n                  : \"text-slate-600 hover:text-slate-950 hover:bg-slate-50\"\n              }`}\n            >\n              Keunggulan Layanan Kami\n            </button>\n          </div>\n        </div>\n\n        {/* Dynamic Items Grid */}\n        <div className=\"mt-12\">\n          {activeTab === \"urgensi\" ? (\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-8\">\n              {urgensiItems.map((item, idx) => (\n                <div\n                  key={idx}\n                  className=\"bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-start space-x-4 hover:border-indigo-300 hover:shadow-md transition-all duration-300 animate-fadeIn\"\n                >\n                  <div className=\"p-3 bg-slate-50 rounded-xl flex-shrink-0\">\n                    {item.icon}\n                  </div>\n                  <div className=\"space-y-1.5 bg-transparent\">\n                    <h3 className=\"font-bold text-lg text-slate-900\">{item.title}</h3>\n                    <p className=\"text-sm text-slate-600 leading-relaxed\">{item.desc}</p>\n                  </div>\n                </div>\n              ))}\n            </div>\n          ) : (\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n              {keunggulanItems.map((item, idx) => (\n                <div\n                  key={idx}\n                  className=\"bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between hover:border-indigo-300 hover:shadow-md transition-all duration-300 animate-fadeIn\"\n                >\n                  <div className=\"space-y-4\">\n                    <div className=\"p-3 bg-slate-50 rounded-xl inline-block\">\n                      {item.icon}\n                    </div>\n                    <div className=\"space-y-2\">\n                      <h4 className=\"font-bold text-base text-slate-900\">{item.title}</h4>\n                      <p className=\"text-xs text-slate-600 leading-relaxed\">{item.desc}</p>\n                    </div>\n                  </div>\n                  <div className=\"pt-4 flex items-center text-xs font-bold text-indigo-700\">\n                    SitusPro Quality Guarantee \342\234\223\n                  </div>\n                </div>\n              ))}\n            </div>\n          )}\n        </div>\n\n        {/* Custom Visual Callout */}\n        <div className=\"mt-12 bg-slate-900 text-white rounded-3xl p-6 sm:p-10 relative overflow-hidden shadow-xl\">\n          {/* Decorative elements */}\n          <div className=\"absolute top-0 right-0 w-64 h-64 bg-indigo-900 rounded-full mix-blend-multiply opacity-20 filter blur-2xl pointer-events-none\" />\n          <div className=\"relative z-10 flex flex-col md:flex-row items-center justify-between gap-6\">\n            <div className=\"space-y-2 text-center md:text-left max-w-xl\">\n              <h4 className=\"text-xl sm:text-2xl font-bold\">Gabungkan Profil, Layanan, & Kontak Dalam Satu Tempat</h4>\n              <p className=\"text-xs sm:text-sm text-slate-300 leading-relaxed\">\n                Kami siap merancang website responsive yang terintegrasi penuh ke Google Maps dan WhatsApp bisnis Anda. Kredibilitas instan, peningkatan konversi, dan kepuasan pelanggan menanti Anda.\n              </p>\n            </div>\n            <button\n              onClick={() => {\n                const cal = document.getElementById(\"kalkulator-custom\");\n                if (cal) cal.scrollIntoView({ behavior: \"smooth\" });\n              }}\n              className=\"bg-white text-slate-900 hover:bg-indigo-50 py-3.5 px-6 rounded-xl text-sm font-bold shadow-md shrink-0 transition-colors\"\n            >\n              Coba Kalkulator Desain Preview\n            </button>\n          </div>\n        </div>"
