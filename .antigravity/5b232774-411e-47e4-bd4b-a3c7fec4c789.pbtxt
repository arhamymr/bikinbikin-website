      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \"react\";\nimport { Plus, Minus, HelpCircle, BadgeInfo } from \"lucide-react\";\nimport { FAQ_LIST } from \"../data\";\n\nexport default function FAQ() {\n  const [activeFAQ, setActiveFAQ] = useState<string | null>(\"faq1\");\n\n  const toggleFAQ = (id: string) => {\n    setActiveFAQ(activeFAQ === id ? null : id);\n  };\n\n  return (\n    <section id=\"faq-section\" className=\"py-20 bg-white\">\n      <div className=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8\">\n        \n        {/* Section Header */}\n        <div className=\"text-center max-w-2xl mx-auto space-y-4 mb-16\">\n          <span className=\"text-xs font-bold uppercase tracking-widest text-emerald-600 bg-emerald-50 py-1 px-3 rounded-full\">\n            Tanya Jawab Umum\n          </span>\n          <h2 className=\"text-3xl sm:text-4xl font-extrabold text-gray-900 leading-tight\">\n            Pertanyaan yang Sering Diajukan\n          </h2>\n          <p className=\"text-base text-gray-600\">\n            Temukan jawaban langsung perihal proses kerja, administrasi kepemilikan domain, hosting, hingga tata cara pengajuan upgrade fitur tambahan.\n          </p>\n        </div>\n\n        {/* Accordions Stack */}\n        <div className=\"space-y-4\">\n          {FAQ_LIST.map((faq) => {\n            const isOpen = activeFAQ === faq.id;\n            return (\n              <div\n                key={faq.id}\n                className={`border rounded-2xl transition-all overflow-hidden ${\n                  isOpen\n                    ? \"bg-slate-25/50 border-emerald-500 shadow-sm\"\n                    : \"bg-white border-gray-150 hover:border-gray-350\"\n                }`}\n              >\n                {/* Accordion Trigger header */}\n                <button\n                  onClick={() => toggleFAQ(faq.id)}\n                  className=\"w-full flex items-center justify-between p-5 text-left focus:outline-none focus:ring-0 cursor-pointer select-none\"\n                >\n                  <div className=\"flex items-center space-x-3.5 pr-4\">\n                    <HelpCircle className={`w-5 h-5 flex-shrink-0 ${isOpen ? \"text-emerald-600\" : \"text-gray-400\"}`} />\n                    <span className=\"font-bold text-sm sm:text-base text-gray-950\">\n                      {faq.question}\n                    </span>\n                  </div>\n                  <div className={`p-1.5 rounded-lg border ${isOpen ? \"bg-emerald-600 border-emerald-600 text-white\" : \"bg-gray-50 border-gray-200 text-gray-600\"} transition-all flex-shrink-0`}>\n                    {isOpen ? (\n                      <Minus className=\"w-3.5 h-3.5 stroke-[3px]\" />\n                    ) : (\n                      <Plus className=\"w-3.5 h-3.5 stroke-[3px]\" />\n                    )}\n                  </div>\n                </button>\n\n                {/* Accordion Content Body */}\n                <div\n                  className={`transition-all duration-300 ease-in-out ${\n                    isOpen ? \"max-h-[500px] border-t border-gray-100 opacity-100\" : \"max-h-0 opacity-0 pointer-events-none\"\n                  }`}\n                >\n                  <div className=\"p-5 sm:p-6 bg-white shrink-0\">\n                    <p className=\"text-xs sm:text-sm text-gray-650 leading-relaxed font-medium\">\n                      {faq.answer}\n                    </p>\n                  </div>\n                </div>\n\n              </div>\n            );\n          })}\n        </div>\n\n        {/* Small sticky box helper */}\n        <div className=\"mt-12 p-5 bg-amber-50 border border-amber-100 rounded-2xl flex items-start space-x-3.5 shadow-sm\">\n          <BadgeInfo className=\"w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5\" />\n          <div className=\"space-y-1\">\n            <h5 className=\"text-xs sm:text-sm font-bold text-amber-950\">Punya pertanyaan kustom yang tidak ada di atas?</h5>\n            <p className=\"text-[11px] sm:text-xs text-amber-800 leading-relaxed\">\n              Silakan langsung hubungi admin kami melalui chat WhatsApp. Tim marketing support SitusPro aktif melayani pertanyaan Anda secara mendalam dan ramah 24 jam sehari.\n            </p>\n          </div>\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
