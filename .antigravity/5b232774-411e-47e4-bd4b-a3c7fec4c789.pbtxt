      target_content: "    <div id=\"website-agency-app\" className=\"min-h-screen bg-white text-gray-800 antialiased selection:bg-emerald-500 selection:text-white\">\n      {/* Premium Header navigation */}\n      <Header \n        onOpenConsultation={handleOpenConsultation}\n        onNavigateToCalculator={handleNavigateToCalculator}\n      />\n\n      {/* Main Container Layout Sections */}\n      <main className=\"relative\">\n        \n        {/* Hero Banner Showcase */}\n        <Hero \n          onOpenConsultation={handleOpenConsultation}\n          onNavigateToCalculator={handleNavigateToCalculator}\n        />\n\n        {/* Credibility and Urgency info grid */}\n        <KenapaWebsite />\n\n        {/* Main Service Presentation tabs */}\n        <Layanan onNavigateToCalculator={handleNavigateToCalculator} />\n\n        {/* Dynamic Custom Configurator Pricing System */}\n        <PricingCalculator />\n\n        {/* Complete Grid portfolio section */}\n        <Portfolio />\n\n        {/* Verified User Testimonials list */}\n        <Testimonials />\n\n        {/* Frequently Asked Questions accordions */}\n        <FAQ />\n\n        {/* Bottom CTA Banner */}\n        <section id=\"bottom-cta-banner\" className=\"py-20 bg-emerald-950 font-sans text-white text-center relative overflow-hidden\">\n          <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-emerald-900/40 via-transparent to-transparent pointer-events-none\" />\n          <div className=\"max-w-4xl mx-auto px-4 relative z-10 space-y-6\">\n            <span className=\"text-xs font-bold uppercase tracking-widest text-emerald-300 bg-white/10 py-1.5 px-4 rounded-full\">\n              Mulai Langkah Anda\n            </span>\n            <h2 className=\"text-3xl sm:text-4xl font-extrabold tracking-tight\">\n              Siap Membuat Website Bisnis Anda Sekarang?\n            </h2>\n            <p className=\"text-sm sm:text-base text-emerald-100 max-w-2xl mx-auto leading-relaxed\">\n              Bangun kehadiran online yang profesional dan mudah dipercaya oleh ribuan calon pelanggan potensial Anda secara nasional. Konsultasikan kebutuhan Anda gratis tanpa dipungut biaya apapun!\n            </p>\n            <div className=\"flex flex-col sm:flex-row justify-center items-center gap-4 pt-4\">\n              <button\n                onClick={handleOpenConsultation}\n                className=\"w-full sm:w-auto inline-flex items-center justify-center text-sm font-bold text-emerald-950 bg-emerald-400 hover:bg-emerald-300 py-3.5 px-8 rounded-xl shadow-lg transition-colors cursor-pointer\"\n              >\n                <Phone className=\"w-4 h-4 mr-1.5\" />\n                Hubungi Kami via WhatsApp\n              </button>\n              <button\n                onClick={handleNavigateToCalculator}\n                className=\"w-full sm:w-auto inline-flex items-center justify-center text-sm font-bold text-white border border-emerald-800 hover:border-emerald-700 hover:bg-white/5 py-3.5 px-8 rounded-xl transition-colors cursor-pointer\"\n              >\n                Pakai Kalkulator Preview\n              </button>\n            </div>\n          </div>\n        </section>\n\n      </main>\n\n      {/* Comprehensive site footer containing company data and links */}\n      <Footer onOpenConsultation={handleOpenConsultation} />\n\n      {/* Consultation Slide-Over drawer Drawer/Modal overlay */}\n      {isConsultationOpen && (\n        <div id=\"consultation-modal-container\" className=\"fixed inset-0 z-50 overflow-hidden\" role=\"dialog\" aria-modal=\"true\">\n          <div className=\"absolute inset-0 bg-slate-950/60 backdrop-blur-sm transition-opacity\" onClick={handleCloseConsultation} />\n          \n          <div className=\"absolute inset-y-0 right-0 max-w-full flex pl-10\">\n            <div className=\"w-screen max-w-md bg-white shadow-2xl flex flex-col justify-between\">\n              \n              {/* Header section of consultation overlay */}\n              <div className=\"p-6 border-b border-gray-150 flex items-center justify-between\">\n                <div className=\"flex items-center space-x-2.5\">\n                  <div className=\"p-2 bg-emerald-100 rounded-xl text-emerald-700\">\n                    <MessageCircle className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <h4 className=\"font-extrabold text-gray-900 text-base\">Konsultasi Desain Gratis</h4>\n                    <p className=\"text-[10px] text-gray-450 uppercase font-bold tracking-widest\">SitusPro Studio</p>\n                  </div>\n                </div>\n                <button\n                  onClick={handleCloseConsultation}\n                  className=\"p-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-50 focus:outline-none cursor-pointer\"\n                >\n                  <X className=\"w-5 h-5 stroke-[2.5]\" />\n                </button>\n              </div>\n\n              {/* Form Content body of consultation overlay */}\n              <form onSubmit={handleConsultationSubmit} className=\"flex-1 overflow-y-auto p-6 space-y-6\">\n                \n                {/* Visual Intro box */}\n                <div className=\"bg-emerald-50 border border-emerald-100 p-4 rounded-2xl space-y-1.5 select-none\">\n                  <p className=\"text-xs font-bold text-emerald-950\">Diskusikan Ide Hebat Anda Bersama Kami</p>\n                  <p className=\"text-[11px] text-emerald-700 leading-relaxed\">\n                    Sebutkan jenis bisnis Anda serta range budget perkiraan. Tim profesional kami akan membantu menyusun rincian struktur halaman sitemap secara kustom & optimal.\n                  </p>\n                </div>\n\n                {/* Input 1 name */}\n                <div className=\"space-y-2\">\n                  <label htmlFor=\"modal-name-input\" className=\"block text-xs font-bold uppercase tracking-wider text-gray-700\">\n                    Nama Bisnis / Merek Anda\n                  </label>\n                  <input\n                    id=\"modal-name-input\"\n                    type=\"text\"\n                    name=\"name\"\n                    value={consultationForm.name}\n                    onChange={handleInputChange}\n                    placeholder=\"Contoh: Kopi Seduh Senja\"\n                    required\n                    className=\"w-full border border-gray-200 rounded-xl py-2.5 px-4 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent font-medium\"\n                  />\n                </div>\n\n                {/* Input 2 category */}\n                <div className=\"space-y-2\">\n                  <label htmlFor=\"modal-category-select\" className=\"block text-xs font-bold uppercase tracking-wider text-gray-700\">\n                    Kategori Bisnis / Profil Jasa\n                  </label>\n                  <select\n                    id=\"modal-category-select\"\n                    name=\"category\"\n                    value={consultationForm.category}\n                    onChange={handleInputChange}\n                    className=\"w-full border border-gray-200 rounded-xl py-2.5 px-4 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent font-medium bg-white\"\n                  >\n                    <option value=\"UMKM / Toko Kelontong\">UMKM / Toko Kelontong</option>\n                    <option value=\"Restoran / Cafe\">Restoran / Cafe / FnB</option>\n                    <option value=\"Company Profile Corporate\">Company Profile / Korporasi</option>\n                    <option value=\"Landing Page Promosi\">Landing Page Produk / Event</option>\n                    <option value=\"Toko Online E-Commerce\">Toko Online E-Commerce</option>\n                    <option value=\"Jasa Profesional (Klinik/Sekolah)\">Jasa Profesional (Klinik/Sekolah/Instansi)</option>\n                    <option value=\"Aplikasi Custom / Sistem Portal\">Aplikasi Custom / Sistem Portal</option>\n                  </select>\n                </div>\n\n                {/* Input 3 Budget range slider / select */}\n                <div className=\"space-y-2\">\n                  <label htmlFor=\"modal-budget-select\" className=\"block text-xs font-bold uppercase tracking-wider text-gray-700\">\n                    Perkiraan Range Budget Pembuatan\n                  </label>\n                  <select\n                    id=\"modal-budget-select\"\n                    name=\"budget\"\n                    value={consultationForm.budget}\n                    onChange={handleInputChange}\n                    className=\"w-full border border-gray-200 rounded-xl py-2.5 px-4 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent font-medium bg-white\"\n                  >\n                    <option value=\"Di bawah Rp 1.500.000\">Di bawah Rp 1.500.000 (Sederhana)</option>\n                    <option value=\"Rp 1.500.000 - Rp 3.500.000\">Rp 1.500.000 - Rp 3.500.000 (Starter/Business)</option>\n                    <option value=\"Rp 3.500.000 - Rp 7.500.000\">Rp 3.500.000 - Rp 7.500.000 (Toko Online/Detail)</option>\n                    <option value=\"Di atas Rp 7.500.000\">Di atas Rp 7.500.000 (Sistem Custom)</option>\n                  </select>\n                </div>\n\n                {/* Input 4 Description target */}\n                <div className=\"space-y-2\">\n                  <label htmlFor=\"modal-desc-textarea\" className=\"block text-xs font-bold uppercase tracking-wider text-gray-700\">\n                    Keinginan Spesial / Deskripsi Tambahan\n                  </label>\n                  <textarea\n                    id=\"modal-desc-textarea\"\n                    name=\"description\"\n                    rows={4}\n                    value={consultationForm.description}\n                    onChange={handleInputChange}\n                    placeholder=\"Contoh: Ingin ada peta interaktif rute klinik kami, tombol link admin, plus slide foto menu makanan...\"\n                    className=\"w-full border border-gray-200 rounded-xl py-2.5 px-4 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent font-medium resize-none\"\n                  />\n                </div>\n\n                {/* Action button */}\n                <div className=\"pt-4\">\n                  <button\n                    type=\"submit\"\n                    className=\"w-full inline-flex items-center justify-center text-sm font-bold text-white bg-emerald-600 hover:bg-emerald-700 py-3.5 px-4 rounded-xl shadow-lg transition-colors cursor-pointer\"\n                  >\n                    <Send className=\"w-4 h-4 mr-1.5\" />\n                    Kirim Form via WhatsApp\n                  </button>\n                </div>\n\n              </form>\n\n              {/* Bottom footer note of consultation overlay */}\n              <div className=\"p-6 bg-gray-50 border-t border-gray-150 text-center select-none\">\n                <p className=\"text-[11px] text-gray-500\">\n                  Data Anda tersimpan aman. Dengan mengirimkan form ini, Anda akan diarahkan langsung menuju layanan CS Whatsapp kami secara instan & responsif.\n                </p>\n              </div>\n\n            </div>\n          </div>\n        </div>\n      )}"
      replacement_content: "    <div id=\"website-agency-app\" className=\"min-h-screen bg-white text-gray-800 antialiased selection:bg-indigo-600 selection:text-white\">\n      {/* Premium Header navigation */}\n      <Header \n        onOpenConsultation={handleOpenConsultation}\n        onNavigateToCalculator={handleNavigateToCalculator}\n      />\n\n      {/* Main Container Layout Sections */}\n      <main className=\"relative\">\n        \n        {/* Hero Banner Showcase */}\n        <Hero \n          onOpenConsultation={handleOpenConsultation}\n          onNavigateToCalculator={handleNavigateToCalculator}\n        />\n\n        {/* Credibility and Urgency info grid */}\n        <KenapaWebsite />\n\n        {/* Main Service Presentation tabs */}\n        <Layanan onNavigateToCalculator={handleNavigateToCalculator} />\n\n        {/* Dynamic Custom Configurator Pricing System */}\n        <PricingCalculator />\n\n        {/* Complete Grid portfolio section */}\n        <Portfolio />\n\n        {/* Verified User Testimonials list */}\n        <Testimonials />\n\n        {/* Frequently Asked Questions accordions */}\n        <FAQ />\n\n        {/* Bottom CTA Banner */}\n        <section id=\"bottom-cta-banner\" className=\"py-20 bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-950 font-sans text-white text-center relative overflow-hidden\">\n          <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-indigo-900/40 via-transparent to-transparent pointer-events-none\" />\n          <div className=\"max-w-4xl mx-auto px-4 relative z-10 space-y-6\">\n            <span className=\"text-xs font-bold uppercase tracking-widest text-indigo-300 bg-white/10 py-1.5 px-4 rounded-full\">\n              Mulai Langkah Anda\n            </span>\n            <h2 className=\"text-3xl sm:text-4xl font-extrabold tracking-tight\">\n              Siap Membuat Website Bisnis Anda Sekarang?\n            </h2>\n            <p className=\"text-sm sm:text-base text-slate-300 max-w-2xl mx-auto leading-relaxed\">\n              Bangun kehadiran online yang profesional dan mudah dipercaya oleh ribuan calon pelanggan potensial Anda secara nasional. Konsultasikan kebutuhan Anda gratis tanpa dipungut biaya apapun!\n            </p>\n            <div className=\"flex flex-col sm:flex-row justify-center items-center gap-4 pt-4\">\n              <button\n                onClick={handleOpenConsultation}\n                className=\"w-full sm:w-auto inline-flex items-center justify-center text-sm font-bold text-white bg-indigo-700 hover:bg-indigo-650 py-3.5 px-8 rounded-full shadow-lg shadow-indigo-950/50 transition-all cursor-pointer\"\n              >\n                <Phone className=\"w-4 h-4 mr-1.5\" />\n                Hubungi Kami via WhatsApp\n              </button>\n              <button\n                onClick={handleNavigateToCalculator}\n                className=\"w-full sm:w-auto inline-flex items-center justify-center text-sm font-bold text-white border border-indigo-800 hover:border-indigo-600 hover:bg-white/10 py-3.5 px-8 rounded-full transition-all cursor-pointer\"\n              >\n                Pakai Kalkulator Preview\n              </button>\n            </div>\n          </div>\n        </section>\n\n      </main>\n\n      {/* Comprehensive site footer containing company data and links */}\n      <Footer onOpenConsultation={handleOpenConsultation} />\n\n      {/* Consultation Slide-Over drawer Drawer/Modal overlay */}\n      {isConsultationOpen && (\n        <div id=\"consultation-modal-container\" className=\"fixed inset-0 z-50 overflow-hidden\" role=\"dialog\" aria-modal=\"true\">\n          <div className=\"absolute inset-0 bg-slate-950/60 backdrop-blur-sm transition-opacity\" onClick={handleCloseConsultation} />\n          \n          <div className=\"absolute inset-y-0 right-0 max-w-full flex pl-10\">\n            <div className=\"w-screen max-w-md bg-white shadow-2xl flex flex-col justify-between\">\n              \n              {/* Header section of consultation overlay */}\n              <div className=\"p-6 border-b border-slate-150 flex items-center justify-between\">\n                <div className=\"flex items-center space-x-2.5\">\n                  <div className=\"p-2 bg-indigo-100 rounded-xl text-indigo-700\">\n                    <MessageCircle className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <h4 className=\"font-extrabold text-gray-900 text-base\">Konsultasi Desain Gratis</h4>\n                    <p className=\"text-[10px] text-slate-400 uppercase font-bold tracking-widest\">SitusPro Studio</p>\n                  </div>\n                </div>\n                <button\n                  onClick={handleCloseConsultation}\n                  className=\"p-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-50 focus:outline-none cursor-pointer\"\n                >\n                  <X className=\"w-5 h-5 stroke-[2.5]\" />\n                </button>\n              </div>\n\n              {/* Form Content body of consultation overlay */}\n              <form onSubmit={handleConsultationSubmit} className=\"flex-1 overflow-y-auto p-6 space-y-6\">\n                \n                {/* Visual Intro box */}\n                <div className=\"bg-indigo-50 border border-indigo-100 p-4 rounded-2xl space-y-1.5 select-none\">\n                  <p className=\"text-xs font-bold text-indigo-950\">Diskusikan Ide Hebat Anda Bersama Kami</p>\n                  <p className=\"text-[11px] text-indigo-750 leading-relaxed font-medium\">\n                    Sebutkan jenis bisnis Anda serta range budget perkiraan. Tim profesional kami akan membantu menyusun rincian struktur halaman sitemap secara kustom & optimal.\n                  </p>\n                </div>\n\n                {/* Input 1 name */}\n                <div className=\"space-y-2\">\n                  <label htmlFor=\"modal-name-input\" className=\"block text-xs font-bold uppercase tracking-wider text-slate-700\">\n                    Nama Bisnis / Merek Anda\n                  </label>\n                  <input\n                    id=\"modal-name-input\"\n                    type=\"text\"\n                    name=\"name\"\n                    value={consultationForm.name}\n                    onChange={handleInputChange}\n                    placeholder=\"Contoh: Kopi Seduh Senja\"\n                    required\n                    className=\"w-full border border-slate-200 rounded-xl py-2.5 px-4 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:border-transparent font-medium\"\n                  />\n                </div>\n\n                {/* Input 2 category */}\n                <div className=\"space-y-2\">\n                  <label htmlFor=\"modal-category-select\" className=\"block text-xs font-bold uppercase tracking-wider text-slate-700\">\n                    Kategori Bisnis / Profil Jasa\n                  </label>\n                  <select\n                    id=\"modal-category-select\"\n                    name=\"category\"\n                    value={consultationForm.category}\n                    onChange={handleInputChange}\n                    className=\"w-full border border-slate-200 rounded-xl py-2.5 px-4 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:border-transparent font-medium bg-white\"\n                  >\n                    <option value=\"UMKM / Toko Kelontong\">UMKM / Toko Kelontong</option>\n                    <option value=\"Restoran / Cafe\">Restoran / Cafe / FnB</option>\n                    <option value=\"Company Profile Corporate\">Company Profile / Korporasi</option>\n                    <option value=\"Landing Page Promosi\">Landing Page Produk / Event</option>\n                    <option value=\"Toko Online E-Commerce\">Toko Online E-Commerce</option>\n                    <option value=\"Jasa Profesional (Klinik/Sekolah)\">Jasa Profesional (Klinik/Sekolah/Instansi)</option>\n                    <option value=\"Aplikasi Custom / Sistem Portal\">Aplikasi Custom / Sistem Portal</option>\n                  </select>\n                </div>\n\n                {/* Input 3 Budget range slider / select */}\n                <div className=\"space-y-2\">\n                  <label htmlFor=\"modal-budget-select\" className=\"block text-xs font-bold uppercase tracking-wider text-slate-700\">\n                    Perkiraan Range Budget Pembuatan\n                  </label>\n                  <select\n                    id=\"modal-budget-select\"\n                    name=\"budget\"\n                    value={consultationForm.budget}\n                    onChange={handleInputChange}\n                    className=\"w-full border border-slate-200 rounded-xl py-2.5 px-4 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:border-transparent font-medium bg-white\"\n                  >\n                    <option value=\"Di bawah Rp 1.500.000\">Di bawah Rp 1.500.000 (Sederhana)</option>\n                    <option value=\"Rp 1.500.000 - Rp 3.500.000\">Rp 1.500.000 - Rp 3.500.000 (Starter/Business)</option>\n                    <option value=\"Rp 3.500.000 - Rp 7.500.000\">Rp 3.500.000 - Rp 7.500.000 (Toko Online/Detail)</option>\n                    <option value=\"Di atas Rp 7.500.000\">Di atas Rp 7.500.000 (Sistem Custom)</option>\n                  </select>\n                </div>\n\n                {/* Input 4 Description target */}\n                <div className=\"space-y-2\">\n                  <label htmlFor=\"modal-desc-textarea\" className=\"block text-xs font-bold uppercase tracking-wider text-slate-700\">\n                    Keinginan Spesial / Deskripsi Tambahan\n                  </label>\n                  <textarea\n                    id=\"modal-desc-textarea\"\n                    name=\"description\"\n                    rows={4}\n                    value={consultationForm.description}\n                    onChange={handleInputChange}\n                    placeholder=\"Contoh: Ingin ada peta interaktif rute klinik kami, tombol link admin, plus slide foto menu makanan...\"\n                    className=\"w-full border border-slate-200 rounded-xl py-2.5 px-4 text-sm text-slate-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:border-transparent font-medium resize-none\"\n                  />\n                </div>\n\n                {/* Action button */}\n                <div className=\"pt-4\">\n                  <button\n                    type=\"submit\"\n                    className=\"w-full inline-flex items-center justify-center text-sm font-bold text-white bg-indigo-700 hover:bg-indigo-650 py-3.5 px-4 rounded-full shadow-lg shadow-indigo-100 transition-colors cursor-pointer\"\n                  >\n                    <Send className=\"w-4 h-4 mr-1.5\" />\n                    Kirim Form via WhatsApp\n                  </button>\n                </div>\n\n              </form>\n\n              {/* Bottom footer note of consultation overlay */}\n              <div className=\"p-6 bg-slate-50 border-t border-slate-150 text-center select-none\">\n                <p className=\"text-[11px] text-slate-500\">\n                  Data Anda tersimpan aman. Dengan mengirimkan form ini, Anda akan diarahkan langsung menuju layanan CS Whatsapp kami secara instan & responsif.\n                </p>\n              </div>\n\n            </div>\n          </div>\n        </div>\n      )}"
    }
